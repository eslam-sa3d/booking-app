rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Role lives in the Auth custom claim (set server-side by onUserCreate /
    // assignStaffRole), never trusted from a client-writable Firestore
    // field. This is the single source of truth every rule below checks.
    function role() {
      return isSignedIn() ? request.auth.token.role : null;
    }

    function isStaff() {
      return role() == 'staff' || role() == 'admin';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function unchanged(field) {
      return !(field in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ---------------- users ----------------
    match /users/{uid} {
      allow read: if isOwner(uid) || isStaff();
      // Clients may only ever create their own profile as 'customer' — role
      // escalation to staff/admin happens exclusively via the
      // assignStaffRole callable, which sets the custom claim and mirrors
      // this field with Admin SDK privileges (bypasses rules entirely).
      allow create: if isOwner(uid) && request.resource.data.role == 'customer';
      // A customer editing their own profile can't touch role or suspended
      // (both are staff/admin-only levers, not self-service). Staff writes
      // (e.g. suspend/reactivate) must tag `updatedBy` — required for the
      // auditLog trigger to attribute the change to a real actor.
      allow update: if (isOwner(uid) && unchanged('role') && unchanged('suspended'))
        || (isStaff() && request.resource.data.updatedBy == request.auth.uid);
      allow delete: if isOwner(uid) || isAdmin();

      match /familyMembers/{memberId} {
        allow read, write: if isOwner(uid) || isStaff();
      }

      // Owned package instances are only ever written by the purchase
      // Cloud Function / staff tooling, never directly by the client.
      // Client purchase writes are rejected here on purpose — package
      // granting goes through the `purchasePackage` callable (Admin SDK,
      // bypasses rules) so a client can never self-report a fake payment
      // success and grant itself session credits.
      match /packages/{userPackageId} {
        allow read: if isOwner(uid) || isStaff();
        allow create, update: if isStaff() && taggedByCaller();
        allow delete: if isStaff();
      }

      // Per-user notification inbox: the owner may only toggle isRead;
      // delivery (create) is always server-side.
      match /inbox/{notificationId} {
        allow read: if isOwner(uid);
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
        allow create, delete: if isStaff();
      }
    }

    // Every staff/admin create+update below must tag `updatedBy` with the
    // caller's own uid — enforced here, consumed by the matching auditLog
    // trigger in functions/src/audit/triggers.ts. Deletes are intentionally
    // *not* required to carry it (a delete has no `request.resource.data`
    // to check); the admin dashboard routes deletes through the
    // `adminDelete` callable instead, which logs them with a verified actor.
    // Direct client deletes stay allowed here only as a defense-in-depth
    // backstop, not the primary path.
    function taggedByCaller() {
      return request.resource.data.updatedBy == request.auth.uid;
    }

    // ---------------- public catalog (guest-readable, staff-writable) ----------------
    match /classes/{classId} {
      allow read: if true;
      allow create, update: if isStaff() && taggedByCaller();
      allow delete: if isStaff();
    }
    match /sessions/{sessionId} {
      allow read: if true;
      // bookedCount/waitlistCount are business-critical counters mutated
      // only by the onBookingCreate/onBookingCancel Cloud Functions
      // (Admin SDK, bypasses rules) — staff edits here are for
      // schedule/capacity/instructor changes, not manual count edits.
      allow create, update: if isStaff() && taggedByCaller();
      allow delete: if isStaff();
    }
    match /branches/{branchId} { allow read: if true; allow write: if isStaff(); }
    match /instructors/{instructorId} {
      allow read: if true;
      allow create, update: if isStaff() && taggedByCaller();
      allow delete: if isStaff();
    }
    match /packages/{packageId} {
      allow read: if true;
      allow create, update: if isStaff() && taggedByCaller();
      allow delete: if isStaff();
    }
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update: if isStaff() && taggedByCaller();
      allow delete: if isStaff();
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isStaff() && taggedByCaller();
      allow delete: if isStaff();
    }
    match /paymentMethods/{methodId} {
      allow read: if true; // mobile checkout reads these unauthenticated-friendly
      // Payments-adjacent config — admin-only, unlike most other content
      // collections (which are isStaff()), matching /transactions.
      allow create, update: if isAdmin() && taggedByCaller();
      allow delete: if isAdmin();
    }
    match /blockedDates/{blockedDateId} {
      allow read: if true; // mobile calendar shows these as unavailable
      allow create, update: if isStaff() && taggedByCaller();
      allow delete: if isStaff();
    }
    // App-wide branding/FAQ/legal content — admin-only per the build spec's
    // explicit "not payments/reports or staff accounts" staff exclusion
    // list; App Content & Settings falls in the same admin-only bucket.
    match /appSettings/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && taggedByCaller();
    }
    match /reviews/{reviewId} {
      allow read: if true;
      // A review must reference a real booking of the caller's own that's
      // actually completed for the class/session being reviewed — without
      // this, any signed-in user could review (and skew an instructor's
      // computed rating for) a class they never attended.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid
        && exists(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId))
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.sessionId == request.resource.data.sessionId
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == 'completed';
      allow update, delete: if isStaff();
    }

    // ---------------- bookings ----------------
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      // createdAt is pinned to the server's own request time so a client
      // can't backdate it to jump the waitlist-promotion queue (which
      // orders by createdAt) ahead of genuinely earlier bookings.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      // Customers may only cancel their own booking (status/cancellation
      // fields), and only by transitioning it into 'cancelled' — never to
      // 'confirmed'/'waitlisted', which would bypass the capacity-owning
      // onBookingCreate/onBookingCancel Cloud Functions entirely.
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'cancelledAt', 'cancellationReason'])
        && request.resource.data.status == 'cancelled';
      allow update, delete: if isStaff();
    }

    // ---------------- transactions ----------------
    // Real charges are recorded server-side by the payment webhook
    // function (Admin SDK). Payments & Reports is admin-only per the build
    // spec's staff exclusion list — refunds and manual entries require
    // isAdmin(), not just isStaff(). Customers may self-service *request* a
    // refund (a narrow field set) on their own transaction; only an admin
    // can resolve that request.
    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['refundRequestStatus', 'refundRequestedAt', 'refundRequestReason'])
        && request.resource.data.refundRequestStatus == 'pending';
      allow create, update: if isAdmin() && taggedByCaller();
      allow delete: if isAdmin();
    }

    // ---------------- staff-authored broadcast notifications ----------------
    match /notifications/{notificationId} {
      allow read, write: if isStaff();
    }

    // ---------------- audit log ----------------
    // Written exclusively by Cloud Functions via the Admin SDK, which
    // bypasses security rules — no client, including admins, writes here
    // directly.
    match /auditLog/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---------------- reminder dedupe markers ----------------
    // Written exclusively by their respective scheduled functions via the
    // Admin SDK — prevents duplicate reminders on overlapping/rerun.
    match /sentPackageExpiryReminders/{markerId} {
      allow read: if isStaff();
      allow write: if false;
    }
    match /sentSessionReminders/{markerId} {
      allow read: if isStaff();
      allow write: if false;
    }
  }
}
